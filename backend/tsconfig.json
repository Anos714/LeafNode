{
  "compilerOptions": {
    /* 1. Target & Environment */
    "target": "ESNext",
    "module": "NodeNext",          
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],

    /* 2. File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,

    /* 3. Strictness (Backend quality ke liye zaroori) */
    "strict": true,
    "noUncheckedIndexedAccess": true, 
    "skipLibCheck": true,            

    /* 4. ESM Specific & Interop */
    "verbatimModuleSyntax": true,   
    "isolatedModules": true,        
    "moduleDetection": "force",
    "esModuleInterop": true,        
    "forceConsistentCasingInFileNames": true,

    /* 5. Clean Output */
    "declaration": true,            
    "removeComments": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}